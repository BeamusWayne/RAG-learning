# ── LLM: OpenAI-compatible (e.g. MiniMax, OpenAI, etc.) ──────────────────────
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
MULTI_RAG_LLM_PROVIDER=openai
MULTI_RAG_LLM_MODEL=gpt-4o

# ── Embedding ─────────────────────────────────────────────────────────────────
# Options: openai | dashscope | ollama
MULTI_RAG_EMBED_PROVIDER=openai
MULTI_RAG_EMBED_MODEL=text-embedding-3-small

# ── (Optional) DashScope / Alibaba Cloud ──────────────────────────────────────
# DASHSCOPE_API_KEY=your_dashscope_key

# ── (Optional) Ollama local ──────────────────────────────────────────────────
# MULTI_RAG_LLM_PROVIDER=ollama
# MULTI_RAG_OLLAMA_LLM=qwen3:4b
# MULTI_RAG_EMBED_PROVIDER=ollama
# MULTI_RAG_OLLAMA_EMBED=nomic-embed-text
